# --- Claude Code → Langfuse tracing (claude-langfuse plugin) ---
# Copy the non-secret lines into your project's .env.example and put the real
# keys in .env (kept out of git). All names use the CC_ prefix so they never
# collide with any other Langfuse-using service in your repo.

CC_TRACE_TO_LANGFUSE=true
CC_PROJECT_NAME=REPLACE_ME
CC_LANGFUSE_BASE_URL=https://langfuse.internal.example.com
CC_LANGFUSE_PUBLIC_KEY=
CC_LANGFUSE_SECRET_KEY=

# Optional:
# CC_LANGFUSE_DEBUG=true          # verbose logging to ~/.claude/state/claude_langfuse.log
# CC_LANGFUSE_MAX_CHARS=20000     # truncation cap for prompt/response/tool bodies
# CC_LANGFUSE_TIMEOUT=8           # per-HTTP-call timeout (s) for the Langfuse client
# CC_LANGFUSE_FLUSH_TIMEOUT=5     # hard cap (s) on the end-of-turn flush so a slow
#                                 # or unreachable Langfuse can't stall Claude Code
